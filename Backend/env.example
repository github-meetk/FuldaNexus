# Environment variables for the FastAPI application
# Copy this file to .env and update the values

# Database (single-service default)
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Fulda Fall 2025 Team2 API

# CORS
# Provide a JSON array (recommended) or comma-separated list of origins
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Admin seeding
ADMIN_EMAIL=admin@informatik.hs-fulda.de
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FIRST_NAMES=Fulda
ADMIN_LAST_NAME=Admin
ADMIN_DOB=1990-01-01

# S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
